---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Starfield from '../components/Starfield.astro';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Gian Barboza – Senior Backend Engineer',
  description = 'Senior Backend Engineer with 10+ years building distributed systems, payments infrastructure, and AI automation. Available for remote work.',
  lang = 'en',
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://gianbarboza.com';
const ogImage = `${siteUrl}/og.png`;
const canonicalPath = Astro.url.pathname.replace(/^\/en(\/|$)/, '/');
const canonicalUrl = new URL(canonicalPath, siteUrl).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gian Barboza',
  jobTitle: 'Senior Backend Engineer',
  description,
  url: siteUrl,
  image: ogImage,
  email: 'mailto:gianelo1992@gmail.com',
  telephone: '+57-304-358-1365',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Rionegro',
    addressRegion: 'Antioquia',
    addressCountry: 'CO',
  },
  sameAs: [
    'https://linkedin.com/in/gian-barboza',
    'https://github.com/gianelo',
  ],
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'Universidad Dr. Rafael Belloso Chacín (URBE)',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Maracaibo',
      addressCountry: 'VE',
    },
  },
  knowsAbout: [
    'Backend Engineering',
    'Distributed Systems',
    'Payments Infrastructure',
    'Stripe', 'PayPal', 'DLocal', 'Shift4', 'Payeezy',
    'Node.js', 'TypeScript', 'PHP', 'Java',
    'MySQL', 'HAProxy', 'DigitalOcean',
    'Fraud Detection', 'PCI Compliance',
    'AI Automation', 'Programmatic SEO',
  ],
  knowsLanguage: [
    { '@type': 'Language', name: 'Spanish', alternateName: 'es' },
    { '@type': 'Language', name: 'English', alternateName: 'en' },
  ],
};
---

<!doctype html>
<html lang={lang} class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Icons (SVG primary, PNG fallback, Apple Touch for home screen) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Gian Barboza" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Person schema for Google Knowledge Graph / rich results -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Theme init: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored ?? 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <Starfield />
    <slot />
    <Analytics />
    <SpeedInsights />

    <!-- Console easter egg: surfaces a CTA for devs who open DevTools -->
    <script is:inline>
      (function () {
        if (typeof console === 'undefined' || !console.log) return;
        const title = 'font-family: Georgia, serif; font-size: 18px; font-style: italic; color: #FFE81F; padding: 8px 0; text-shadow: 0 0 8px rgba(255,232,31,0.4);';
        const heading = 'font-size: 13px; font-weight: 600; color: inherit; padding-top: 4px;';
        const muted = 'font-size: 12px; color: #888;';
        console.log('%cThese aren\'t the bugs you\'re looking for.', title);
        console.log('%cLooking for a senior backend engineer?', heading);
        console.log('%cgianelo1992@gmail.com   linkedin.com/in/gian-barboza', muted);
      })();
    </script>

    <!-- Scroll animation observer -->
    <script is:inline>
      (function () {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        function initObserver() {
          document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initObserver);
        } else {
          initObserver();
        }
      })();
    </script>
  </body>
</html>
