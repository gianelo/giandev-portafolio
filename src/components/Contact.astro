---
import ContactModal from './ContactModal.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { lang, t } = Astro.props;

const linkedinUrl = t('contact.linkedin.url');
const githubUrl = t('contact.github.url');
const phoneDisplay = t('contact.phone');
const phoneUrl = t('contact.phone.url');
const email = t('contact.email');

const year = new Date().getFullYear();
const footerCopy = t('term.footer.copy').replace('{year}', String(year));
---

<section class="cta" id="contact">
  <div class="cta-eyebrow reveal">{t('term.cta.eyebrow')}</div>
  <h2 class="cta-title reveal" set:html={t('term.cta.title.html')}></h2>
  <p class="cta-sub reveal">{t('term.cta.sub')}</p>

  <div class="cta-actions reveal">
    <button type="button" class="btn primary" data-open-contact>
      {t('term.cta.contact')} <span class="arrow">→</span>
    </button>
    <a class="btn" href={t('cta.cv.url')} download>
      {t('term.cta.resume')}
    </a>
  </div>

  <div class="cta-contacts reveal">
    <a href={`mailto:${email}`}>{email}</a>
    <a href={phoneUrl} target="_blank" rel="noopener noreferrer">{phoneDisplay}</a>
    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer">linkedin.com/in/gian-barboza</a>
    <a href={githubUrl} target="_blank" rel="noopener noreferrer">github.com/gianelo</a>
  </div>
</section>

<ContactModal lang={lang} t={t} />

<footer class="footer">
  <span>{footerCopy}</span>
  <span>{t('term.footer.deploy')}</span>
</footer>
