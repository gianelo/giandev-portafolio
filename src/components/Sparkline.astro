---
export interface Props {
  seed?: number;
  color?: string;
}

const { seed = 1, color = 'currentColor' } = Astro.props;

// Deterministic gentle wiggle — matches the design's algorithm
const pts: [number, number][] = [];
let v = 50;
for (let i = 0; i < 40; i++) {
  const r = Math.sin(seed * 13.7 + i * 1.13) * 0.5 + Math.cos(seed * 7.1 + i * 0.71) * 0.5;
  v = Math.max(10, Math.min(90, v + r * 8));
  pts.push([i * (100 / 39), 100 - v]);
}
const d = pts.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(2)},${p[1].toFixed(2)}`).join(' ');
---

<svg class="stat-spark" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
  <path d={d} fill="none" stroke={color} stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.7" />
</svg>
