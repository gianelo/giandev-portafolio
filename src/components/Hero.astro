---
import Terminal from './Terminal.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;

const linkedinUrl = 'https://linkedin.com/in/gian-barboza';
const githubUrl = 'https://github.com/gianelo';
---

<header class="hero wrap">
  <div class="hero-meta reveal">
    <span class="live"><span class="dot"></span>{t('term.hero.available')}</span>
    <span>·</span>
    <span>{t('term.hero.location')}</span>
    <span>·</span>
    <span>{t('term.hero.years')}</span>
  </div>

  <div class="hero-grid">
    <div>
      <h1 class="hero-name reveal">
        <span aria-hidden="true">Gian<br />Barboza<span class="accent">.</span></span>
        <span class="sr-only">Gian Barboza — {t('meta.h1.role')}</span>
      </h1>

      <p class="hero-tagline reveal" set:html={t('term.hero.tagline.html')}></p>

      <div class="hero-actions reveal">
        <button type="button" class="btn primary" data-open-contact>
          {t('term.cta.contact')} <span class="arrow">→</span>
        </button>
        <a class="btn" href={t('cta.cv.url')} download>
          {t('term.cta.resume')}
        </a>
        <a class="btn" href={linkedinUrl} target="_blank" rel="noopener noreferrer">
          LinkedIn
        </a>
        <a class="btn" href={githubUrl} target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </div>
    </div>

    <div class="reveal reveal-delay-2">
      <Terminal />
    </div>
  </div>
</header>
