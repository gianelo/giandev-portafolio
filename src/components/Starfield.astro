---
/**
 * Starfield — fixed-position layer of ~70 stars in dark mode.
 * Each star has its own twinkle delay + duration so they animate
 * independently. Hidden in light mode via CSS.
 */

const STAR_COUNT = 35;

const stars = Array.from({ length: STAR_COUNT }, (_, i) => {
  const a = (i * 12345 + 7) % 10000;
  const b = (i * 67891 + 13) % 10000;
  const c = (i * 23456 + 19) % 100;
  const d = (i * 78901 + 23) % 800;
  const e = (i * 34567 + 29) % 600;
  return {
    x: a / 100,
    y: b / 100,
    size: 1 + (c % 3) * 0.5,
    delay: -(d / 100),
    duration: 3 + e / 100,
  };
});
---

<div class="starfield" aria-hidden="true">
  {stars.map((s) => (
    <span
      class="star"
      style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;animation-delay:${s.delay}s;animation-duration:${s.duration}s;`}
    />
  ))}
</div>
