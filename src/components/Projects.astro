---
import SectionHeading from './SectionHeading.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;

type CaseKey = 'infra' | 'seo' | 'fraud' | 'payments';

const cases: { key: CaseKey; tags: string[] }[] = [
  {
    key: 'infra',
    tags: ['MySQL Replication', 'HAProxy', 'DigitalOcean', 'Nginx', 'Linux'],
  },
  {
    key: 'seo',
    tags: ['ChatGPT-4o', 'Node.js', 'Programmatic SEO', 'AI', 'PHP'],
  },
  {
    key: 'fraud',
    tags: ['Factory Pattern', 'SRP', 'Device Fingerprinting', 'Rules Engine', 'n8n'],
  },
  {
    key: 'payments',
    tags: ['Stripe', 'PayPal', 'DLocal', 'Shift4', 'Payeezy', '3DS', 'Apple Pay', 'Google Pay'],
  },
];
---

<section class="section wrap" id="cases">
  <SectionHeading
    label={t('term.section.03.label')}
    title={t('term.section.03.title')}
    sub={t('term.section.03.sub')}
  />

  <div class="case-list reveal">
    {cases.map((c, i) => (
      <article class={`case ${i === 0 ? 'open' : ''}`} data-case={c.key}>
        <button type="button" class="case-head" aria-expanded={i === 0 ? 'true' : 'false'}>
          <span class="case-num">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="case-title">{t(`projects.${c.key}.title`)}</h3>
          <div class="case-meta">
            <span class="metric">{t(`term.case.${c.key}.metric`)}</span>
            <span class="case-toggle" aria-hidden="true">+</span>
          </div>
        </button>
        <div class="case-body">
          <div class="case-body-inner">
            <div class="case-grid">
              <div class="label">{t('term.case.label.context')}</div>
              <div class="text">{t(`projects.${c.key}.context`)}</div>

              <div class="label">{t('term.case.label.problem')}</div>
              <div class="text">{t(`projects.${c.key}.problem`)}</div>

              <div class="label">{t('term.case.label.decision')}</div>
              <div class="text">{t(`projects.${c.key}.decision`)}</div>

              <div class="label">{t('term.case.label.result')}</div>
              <div class="text">
                <div class="case-result">
                  <span class="num">{t(`term.case.${c.key}.result.num`)}</span>
                  <span>{t(`term.case.${c.key}.result.text`)}</span>
                </div>
                <div class="tag-row">
                  {c.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script is:inline>
  (function () {
    document.querySelectorAll('.case').forEach((card) => {
      const head = card.querySelector('.case-head');
      if (!head) return;
      head.addEventListener('click', () => {
        const isOpen = card.classList.contains('open');
        // Close all
        document.querySelectorAll('.case.open').forEach((other) => {
          other.classList.remove('open');
          const btn = other.querySelector('.case-head');
          if (btn) btn.setAttribute('aria-expanded', 'false');
        });
        // Open this one if it wasn't already
        if (!isOpen) {
          card.classList.add('open');
          head.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>
