---
import SectionHeading from './SectionHeading.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;

type MilestoneKey = 'now' | 'freelance' | 'cto' | 'fermat';

const milestones: { key: MilestoneKey; current?: boolean }[] = [
  { key: 'now',       current: true },
  { key: 'freelance' },
  { key: 'cto'       },
  { key: 'fermat'    },
];
---

<section class="section wrap" id="journey">
  <SectionHeading
    label={t('term.section.01.label')}
    title={t('term.section.01.title')}
    sub={t('term.section.01.sub')}
  />

  <div class="journey-list">
    {milestones.map((m, i) => (
      <div class={`journey-item reveal reveal-delay-${Math.min(i + 1, 4)}`}>
        <div class="journey-date">{t(`timeline.${m.key}.period`)}</div>
        <div>
          <h3 class="journey-role">
            {t(`timeline.${m.key}.role`)}
            {m.current && <span class="pill">{t('term.journey.current')}</span>}
          </h3>
          <p class="journey-company">{t(`timeline.${m.key}.company`)}</p>
          <p class="journey-desc">{t(`timeline.${m.key}.desc`)}</p>
        </div>
      </div>
    ))}
  </div>
</section>
