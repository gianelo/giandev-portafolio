---
import SectionHeading from './SectionHeading.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;

const cards = [
  { key: 'years',    color: 'hover:border-yellow-400/60 dark:hover:border-yellow-500/60' },
  { key: 'uptime',   color: 'hover:border-emerald-400/60 dark:hover:border-emerald-500/60' },
  { key: 'volume',   color: 'hover:border-blue-400/60 dark:hover:border-blue-500/60' },
  { key: 'payments', color: 'hover:border-violet-400/60 dark:hover:border-violet-500/60' },
];
---

<section id="impact" class="py-20 px-6">
  <div class="max-w-4xl mx-auto">

    <SectionHeading title={t('impact.title')} />

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
      {cards.map((card, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} group relative bg-white dark:bg-zinc-900/60 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-6 text-center ${card.color} transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-black/5 dark:hover:shadow-black/20`}
        >
          <div class="text-3xl md:text-4xl font-bold text-yellow-500 dark:text-yellow-400 mb-2 tabular-nums">
            {t(`impact.${card.key}.number`)}
          </div>
          <p class="text-xs md:text-sm text-zinc-500 dark:text-zinc-400 font-medium leading-snug">
            {t(`impact.${card.key}.label`)}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
