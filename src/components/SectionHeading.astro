---
export interface Props {
  emoji: string;
  title: string;
  subtitle?: string;
}

const { emoji, title, subtitle } = Astro.props;
---

<div class="reveal flex flex-col items-center mb-14 text-center">
  <span class="text-4xl mb-3">{emoji}</span>
  <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">
    {title}
  </h2>
  <div class="mt-3 w-12 h-1 rounded-full bg-yellow-400"></div>
  {subtitle && (
    <p class="mt-4 text-sm md:text-base text-gray-500 dark:text-gray-400 max-w-xl">
      {subtitle}
    </p>
  )}
</div>
