---
export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<div
  id="contact-modal"
  class="fixed inset-0 z-[100] hidden opacity-0 flex items-center justify-center p-4 overflow-y-auto"
  style="transition: opacity 200ms ease;"
  aria-hidden="true"
  aria-labelledby="contact-modal-title"
  role="dialog"
  aria-modal="true"
>
  <div data-overlay class="modal-overlay absolute inset-0" aria-hidden="true"></div>

  <div
    id="contact-dialog"
    class="modal-dialog relative w-full max-w-md transform scale-95"
    style="transition: transform 200ms ease;"
  >
    <button
      type="button"
      data-close-contact
      aria-label={t('contact.modal.close')}
      class="absolute top-3 right-3 nav-tool"
      style="font-family: var(--font-mono); font-size: 11px;"
    >
      <span aria-hidden="true">ESC</span>
    </button>

    <div style="padding: 28px 28px 24px;">
      <div class="section-label" style="margin-bottom: 12px;">
        <span>~/contact.form</span>
      </div>

      <h3 id="contact-modal-title" class="section-title" style="font-size: 22px; margin-bottom: 6px;">
        {t('contact.modal.title')}
      </h3>
      <p style="color: var(--fg-muted); font-size: 14px; margin: 0 0 24px; line-height: 1.5;">
        {t('contact.modal.intro')}
      </p>

      <form id="contact-form" class="space-y-4" novalidate style="display: flex; flex-direction: column; gap: 16px;">
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value="Nuevo contacto desde giandev portafolio" />
        <input type="hidden" name="from_name" value="giandev portafolio" />

        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div>
          <label for="cm-name" class="modal-label">
            <span>01 / {t('contact.form.name')}</span>
          </label>
          <input
            id="cm-name"
            name="name"
            type="text"
            required
            maxlength="100"
            autocomplete="name"
            placeholder={t('contact.form.name.placeholder')}
            class="modal-input"
          />
        </div>

        <div>
          <label for="cm-email" class="modal-label">
            <span>02 / {t('contact.form.email')}</span>
          </label>
          <input
            id="cm-email"
            name="email"
            type="email"
            required
            maxlength="200"
            autocomplete="email"
            placeholder={t('contact.form.email.placeholder')}
            class="modal-input"
          />
        </div>

        <div>
          <label for="cm-message" class="modal-label">
            <span>03 / {t('contact.form.message')}</span>
          </label>
          <textarea
            id="cm-message"
            name="message"
            required
            maxlength="2000"
            rows="4"
            placeholder={t('contact.form.message.placeholder')}
            class="modal-input"
            style="resize: none; font-family: var(--font-sans);"
          ></textarea>
        </div>

        <p style="font-size: 11px; color: var(--fg-faint); line-height: 1.5; margin: 0;">
          {t('contact.form.privacy')}
        </p>

        <button
          type="submit"
          id="cm-submit"
          class="btn primary"
          style="width: 100%; justify-content: center;"
        >
          <span id="cm-submit-label">{t('contact.form.submit')}</span>
          <svg id="cm-submit-spinner" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
        </button>

        <div id="cm-status" role="status" aria-live="polite" class="hidden"></div>
      </form>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    labels: {
      submit: t('contact.form.submit'),
      sending: t('contact.form.sending'),
      success: t('contact.form.success'),
      error: t('contact.form.error'),
      validation: t('contact.form.validation'),
    },
  }}
>
  (function () {
    const BOT_MIN_OPEN_MS = 2000;
    const CLOSE_ANIM_MS = 200;
    const SUCCESS_CLOSE_DELAY_MS = 2200;
    const FOCUSABLE = 'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]):not([type="hidden"]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';

    const modal = document.getElementById('contact-modal');
    const dialog = document.getElementById('contact-dialog');
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('cm-submit');
    const submitLabel = document.getElementById('cm-submit-label');
    const spinner = document.getElementById('cm-submit-spinner');
    const status = document.getElementById('cm-status');

    if (!modal || !form) return;

    // Portal: lift modal to body so inert on body children doesn't trap it.
    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    let openedAt = 0;
    let lastTrigger = null;
    let inertedSiblings = [];

    function getFocusable() {
      return Array.from(dialog.querySelectorAll(FOCUSABLE)).filter(
        (el) => !el.hasAttribute('disabled') && el.offsetParent !== null
      );
    }

    function setBackgroundInert(on) {
      if (on) {
        inertedSiblings = [];
        Array.from(document.body.children).forEach((el) => {
          if (el === modal) return;
          if (el.tagName === 'SCRIPT' || el.tagName === 'STYLE') return;
          if (!el.hasAttribute('inert')) {
            el.setAttribute('inert', '');
            inertedSiblings.push(el);
          }
        });
      } else {
        inertedSiblings.forEach((el) => el.removeAttribute('inert'));
        inertedSiblings = [];
      }
    }

    function open() {
      lastTrigger = document.activeElement;
      hideStatus();
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      setBackgroundInert(true);
      requestAnimationFrame(() => {
        modal.classList.remove('opacity-0');
        dialog.classList.remove('scale-95');
        dialog.classList.add('scale-100');
      });
      document.body.style.overflow = 'hidden';
      openedAt = Date.now();
      setTimeout(() => document.getElementById('cm-name')?.focus(), 150);
    }

    function close() {
      modal.classList.add('opacity-0');
      dialog.classList.add('scale-95');
      dialog.classList.remove('scale-100');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        setBackgroundInert(false);
        document.body.style.overflow = '';
        form.reset();
        clearInvalidState();
        if (lastTrigger && typeof lastTrigger.focus === 'function') {
          lastTrigger.focus();
        }
        lastTrigger = null;
      }, CLOSE_ANIM_MS);
    }

    function hideStatus() {
      status.className = 'hidden';
      status.removeAttribute('style');
      status.textContent = '';
    }

    function showStatus(msg, type) {
      const isOk = type === 'success';
      status.textContent = msg;
      status.className = '';
      status.style.cssText = `
        font-family: var(--font-mono);
        font-size: 12px;
        text-align: center;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid ${isOk ? 'oklch(0.78 0.16 150 / 0.4)' : 'oklch(0.68 0.18 25 / 0.4)'};
        background: ${isOk ? 'oklch(0.78 0.16 150 / 0.08)' : 'oklch(0.68 0.18 25 / 0.08)'};
        color: ${isOk ? 'var(--green)' : 'var(--red)'};
      `;
    }

    function clearInvalidState() {
      form.querySelectorAll('[aria-invalid="true"]').forEach((el) => {
        el.setAttribute('aria-invalid', 'false');
      });
    }

    form.querySelectorAll('input, textarea').forEach((field) => {
      if (field.type === 'hidden' || field.name === 'botcheck') return;
      field.addEventListener('invalid', () => field.setAttribute('aria-invalid', 'true'));
      field.addEventListener('input', () => {
        if (field.checkValidity()) field.setAttribute('aria-invalid', 'false');
      });
    });

    document.querySelectorAll('[data-open-contact]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    modal.querySelectorAll('[data-close-contact], [data-overlay]').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (modal.classList.contains('hidden')) return;
      if (e.key === 'Escape') {
        close();
        return;
      }
      if (e.key === 'Tab') {
        const focusable = getFocusable();
        if (focusable.length === 0) {
          e.preventDefault();
          return;
        }
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        const active = document.activeElement;
        if (e.shiftKey && (active === first || !dialog.contains(active))) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && (active === last || !dialog.contains(active))) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (Date.now() - openedAt < BOT_MIN_OPEN_MS) return;
      if (!form.checkValidity()) {
        form.reportValidity();
        showStatus(labels.validation, 'error');
        const firstInvalid = form.querySelector(':invalid:not([type="hidden"])');
        if (firstInvalid) firstInvalid.focus();
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = labels.sending;
      spinner.classList.remove('hidden');
      hideStatus();

      const data = new FormData(form);

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();

        if (res.ok && json.success) {
          showStatus(labels.success, 'success');
          setTimeout(close, SUCCESS_CLOSE_DELAY_MS);
        } else {
          showStatus(labels.error, 'error');
        }
      } catch {
        showStatus(labels.error, 'error');
      } finally {
        submitBtn.disabled = false;
        submitLabel.textContent = labels.submit;
        spinner.classList.add('hidden');
      }
    });
  })();
</script>
