---
export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

const inputClass = 'w-full px-4 py-2.5 rounded-xl bg-zinc-50 dark:bg-zinc-800/60 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition';

const labelClass = 'block font-mono text-[0.65rem] uppercase tracking-[0.25em] text-zinc-600 dark:text-zinc-400 mb-2 flex items-center gap-2';
---

<div
  id="contact-modal"
  class="fixed inset-0 z-[100] hidden opacity-0 flex items-center justify-center p-4 overflow-y-auto transition-opacity duration-200"
  aria-hidden="true"
  aria-labelledby="contact-modal-title"
  role="dialog"
  aria-modal="true"
>
  <div
    data-overlay
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
  ></div>

  <div
    id="contact-dialog"
    class="relative w-full max-w-md bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl shadow-2xl shadow-black/20 transform scale-95 transition-transform duration-200"
  >
    <div class="h-1 w-full rounded-t-2xl bg-gradient-to-r from-yellow-400 to-amber-500"></div>

    <button
      type="button"
      data-close-contact
      aria-label={t('contact.modal.close')}
      class="absolute top-3 right-3 p-2 rounded-full text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-white/10 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="px-6 pt-8 pb-6 md:px-8 md:pt-10 md:pb-8">
      <div class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-zinc-500 dark:text-zinc-500 mb-3 flex items-center gap-2">
        <span class="inline-block w-4 h-px bg-zinc-400 dark:bg-zinc-700"></span>
        <span>§ Contact</span>
      </div>
      <h3 id="contact-modal-title" class="font-display text-2xl md:text-3xl font-medium text-zinc-900 dark:text-white leading-tight mb-3 tracking-tight">
        <em class="font-display-italic font-light text-yellow-600 dark:text-yellow-400">{t('contact.modal.title').split(' ')[0]}</em>{t('contact.modal.title').includes(' ') && (
          <span> {t('contact.modal.title').split(' ').slice(1).join(' ')}</span>
        )}
      </h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-7">
        {t('contact.modal.intro')}
      </p>

      <form id="contact-form" class="space-y-4" novalidate>
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value="Nuevo contacto desde giandev portafolio" />
        <input type="hidden" name="from_name" value="giandev portafolio" />

        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div>
          <label for="cm-name" class={labelClass}>
            <span class="inline-block w-3 h-px bg-zinc-400 dark:bg-zinc-600"></span>
            <span>01 / {t('contact.form.name')}</span>
          </label>
          <input
            id="cm-name"
            name="name"
            type="text"
            required
            maxlength="100"
            autocomplete="name"
            placeholder={t('contact.form.name.placeholder')}
            class={inputClass}
          />
        </div>

        <div>
          <label for="cm-email" class={labelClass}>
            <span class="inline-block w-3 h-px bg-zinc-400 dark:bg-zinc-600"></span>
            <span>02 / {t('contact.form.email')}</span>
          </label>
          <input
            id="cm-email"
            name="email"
            type="email"
            required
            maxlength="200"
            autocomplete="email"
            placeholder={t('contact.form.email.placeholder')}
            class={inputClass}
          />
        </div>

        <div>
          <label for="cm-message" class={labelClass}>
            <span class="inline-block w-3 h-px bg-zinc-400 dark:bg-zinc-600"></span>
            <span>03 / {t('contact.form.message')}</span>
          </label>
          <textarea
            id="cm-message"
            name="message"
            required
            maxlength="2000"
            rows="4"
            placeholder={t('contact.form.message.placeholder')}
            class={`${inputClass} resize-none`}
          ></textarea>
        </div>

        <p class="text-xs text-zinc-500 dark:text-zinc-500 leading-relaxed">
          {t('contact.form.privacy')}
        </p>

        <button
          type="submit"
          id="cm-submit"
          class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-yellow-400 hover:bg-yellow-300 dark:bg-yellow-500 dark:hover:bg-yellow-400 text-zinc-900 font-mono uppercase tracking-[0.18em] text-xs md:text-sm font-semibold transition-all shadow-lg shadow-yellow-400/25 hover:shadow-yellow-400/40 disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:-translate-y-0"
        >
          <span id="cm-submit-label">{t('contact.form.submit')}</span>
          <svg id="cm-submit-spinner" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin">
            <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
          </svg>
        </button>

        <div
          id="cm-status"
          role="status"
          aria-live="polite"
          class="hidden"
        ></div>
      </form>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    labels: {
      submit: t('contact.form.submit'),
      sending: t('contact.form.sending'),
      success: t('contact.form.success'),
      error: t('contact.form.error'),
    },
  }}
>
  (function () {
    const BOT_MIN_OPEN_MS = 2000;
    const CLOSE_ANIM_MS = 200;
    const SUCCESS_CLOSE_DELAY_MS = 2200;
    const STATUS_BASE = 'text-sm font-medium text-center py-2 rounded-lg';

    const modal = document.getElementById('contact-modal');
    const dialog = document.getElementById('contact-dialog');
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('cm-submit');
    const submitLabel = document.getElementById('cm-submit-label');
    const spinner = document.getElementById('cm-submit-spinner');
    const status = document.getElementById('cm-status');

    if (!modal || !form) return;

    let openedAt = 0;

    function open() {
      hideStatus();
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        modal.classList.remove('opacity-0');
        dialog.classList.remove('scale-95');
        dialog.classList.add('scale-100');
      });
      document.body.style.overflow = 'hidden';
      openedAt = Date.now();
      setTimeout(() => document.getElementById('cm-name')?.focus(), 150);
    }

    function close() {
      modal.classList.add('opacity-0');
      dialog.classList.add('scale-95');
      dialog.classList.remove('scale-100');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        form.reset();
      }, CLOSE_ANIM_MS);
    }

    function hideStatus() {
      status.className = 'hidden';
    }

    function showStatus(msg, type) {
      const variant = type === 'success'
        ? 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-300'
        : 'bg-red-50 dark:bg-red-950/30 text-red-700 dark:text-red-300';
      status.textContent = msg;
      status.className = `${STATUS_BASE} ${variant}`;
    }

    document.querySelectorAll('[data-open-contact]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    modal.querySelectorAll('[data-close-contact], [data-overlay]').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (Date.now() - openedAt < BOT_MIN_OPEN_MS) return;
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = labels.sending;
      spinner.classList.remove('hidden');
      hideStatus();

      const data = new FormData(form);

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();

        if (res.ok && json.success) {
          showStatus(labels.success, 'success');
          setTimeout(close, SUCCESS_CLOSE_DELAY_MS);
        } else {
          showStatus(labels.error, 'error');
        }
      } catch {
        showStatus(labels.error, 'error');
      } finally {
        submitBtn.disabled = false;
        submitLabel.textContent = labels.submit;
        spinner.classList.add('hidden');
      }
    });
  })();
</script>
