---
export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { lang, t } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangUrl = `/${otherLang}/`;
---

<nav class="nav" aria-label={lang === 'es' ? 'Navegación principal' : 'Primary'}>
  <div class="nav-inner">
    <div class="nav-mark" aria-hidden="true">
      <span class="dot"></span>
      <span>gian.barboza</span>
      <span class="meta">· <span id="nav-clock">--:--</span> GMT-5</span>
    </div>

    <div class="nav-links">
      <a href="#journey">{t('nav.timeline')}</a>
      <a href="#impact">{t('nav.impact')}</a>
      <a href="#cases">{t('nav.projects')}</a>
      <a href="#stack">{t('nav.stack')}</a>
    </div>

    <div class="nav-tools">
      <a
        href={otherLangUrl}
        class="nav-tool"
        aria-label={t('nav.lang.switch')}
        lang={otherLang}
        hreflang={otherLang}
      >
        {otherLang === 'en' ? 'EN' : 'ES'}
      </a>

      <button
        id="theme-toggle"
        class="nav-tool"
        aria-label={t('nav.toggle.dark')}
        aria-pressed="false"
        type="button"
      >
        <span id="theme-label">DARK</span>
      </button>

      <button type="button" class="nav-cta" data-open-contact>
        {t('term.nav.cta')}
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    // Live clock — Bogotá / GMT-5 (covers Rionegro)
    const clock = document.getElementById('nav-clock');
    if (clock) {
      function fmt() {
        return new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/Bogota',
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
        }).format(new Date());
      }
      clock.textContent = fmt();
      setInterval(() => { clock.textContent = fmt(); }, 30000);
    }

    // Theme toggle — label shows the TARGET mode (mirrors the lang switcher behavior)
    const btn = document.getElementById('theme-toggle');
    const label = document.getElementById('theme-label');
    function syncLabel() {
      if (!btn || !label) return;
      const isLight = document.documentElement.classList.contains('light');
      // If currently light → button offers DARK; if currently dark → button offers LIGHT
      label.textContent = isLight ? 'DARK' : 'LIGHT';
      btn.setAttribute('aria-label', isLight ? 'Switch to dark mode' : 'Switch to light mode');
      btn.setAttribute('aria-pressed', isLight ? 'true' : 'false');
    }
    syncLabel();
    if (btn) {
      btn.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncLabel();
      });
    }
  })();
</script>
