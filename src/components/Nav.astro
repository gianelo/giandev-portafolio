---
export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { lang, t } = Astro.props;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangUrl = `/${otherLang}/`;
---

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-mark" href="#">
      <span class="dot"></span>
      <span>gian.barboza</span>
      <span class="meta">· <span id="nav-clock">--:--</span> GMT-5</span>
    </a>

    <div class="nav-links">
      <a href="#journey">{t('nav.timeline')}</a>
      <a href="#impact">{t('nav.impact')}</a>
      <a href="#cases">{t('nav.projects')}</a>
      <a href="#stack">{t('nav.stack')}</a>
    </div>

    <div class="nav-tools">
      <a
        href={otherLangUrl}
        class="nav-tool"
        aria-label={`Switch to ${otherLang === 'en' ? 'English' : 'Español'}`}
      >
        {otherLang === 'en' ? 'EN' : 'ES'}
      </a>

      <button
        id="theme-toggle"
        class="nav-tool"
        aria-label={t('nav.toggle.dark')}
        type="button"
      >
        <span id="theme-label">DARK</span>
      </button>

      <button type="button" class="nav-cta" data-open-contact>
        {t('term.nav.cta')}
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    // Live clock — Bogotá / GMT-5 (covers Rionegro)
    const clock = document.getElementById('nav-clock');
    if (clock) {
      function fmt() {
        return new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/Bogota',
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
        }).format(new Date());
      }
      clock.textContent = fmt();
      setInterval(() => { clock.textContent = fmt(); }, 30000);
    }

    // Theme toggle
    const btn = document.getElementById('theme-toggle');
    const label = document.getElementById('theme-label');
    function syncLabel() {
      if (!label) return;
      label.textContent = document.documentElement.classList.contains('light') ? 'LIGHT' : 'DARK';
    }
    syncLabel();
    if (btn) {
      btn.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncLabel();
      });
    }
  })();
</script>
