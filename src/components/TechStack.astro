---
import SectionHeading from './SectionHeading.astro';

export interface Props {
  lang: string;
  t: (key: string) => string;
}

const { t } = Astro.props;

const categories = [
  {
    key: 'backend',
    glyph: '/srv',
    tags: ['Node.js', 'TypeScript', 'Next.js', 'PHP', 'Java', 'REST APIs', 'Gateway Pattern', 'Design Patterns', 'Clean Architecture'],
  },
  {
    key: 'infra',
    glyph: '/infra',
    tags: ['Linux', 'DigitalOcean', 'HAProxy', 'Nginx', 'MySQL Replication', 'Cronjobs', 'CI/CD'],
  },
  {
    key: 'payments',
    glyph: '/pay',
    tags: ['Stripe', 'PayPal', 'DLocal', 'Shift4', 'Payeezy', 'Payment Routing', 'Fraud Engines', 'Device Fingerprinting', 'PCI Compliance'],
  },
  {
    key: 'ai',
    glyph: '/ai',
    tags: ['n8n', 'LLM Integration', 'AI-Assisted Fraud', 'Programmatic SEO', 'Content Automation', 'Web Scraping'],
  },
];
---

<section class="section wrap" id="stack">
  <SectionHeading
    label={t('term.section.04.label')}
    title={t('term.section.04.title')}
    sub={t('term.section.04.sub')}
  />

  <div class="exp-grid">
    {categories.map((cat, i) => (
      <div class={`exp-card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
        <div class="exp-head">
          <h3 class="exp-name">{t(`stack.${cat.key}.title`)}</h3>
          <span class="exp-glyph">{cat.glyph}</span>
        </div>
        <div class="exp-tags">
          {cat.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>
