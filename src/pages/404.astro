---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page Not Found · Gian Barboza"
  description="The page you're looking for doesn't exist or has been moved."
  lang="en"
>
  <main class="min-h-screen flex items-center justify-center px-6 py-20">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-8xl md:text-9xl font-bold text-yellow-500 dark:text-yellow-400 mb-6 tabular-nums">
        404
      </p>

      <h1
        class="text-2xl md:text-3xl font-semibold italic text-zinc-800 dark:text-zinc-100 mb-4"
        style="font-family: Georgia, 'Times New Roman', serif;"
      >
        "These aren't the routes you're looking for."
      </h1>

      <p class="text-base md:text-lg text-zinc-600 dark:text-zinc-400 mb-10 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-yellow-400 hover:bg-yellow-300 dark:bg-yellow-500 dark:hover:bg-yellow-400 text-zinc-900 font-semibold text-base transition-all shadow-lg shadow-yellow-400/25 hover:shadow-yellow-400/40 hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Back to home
      </a>
    </div>
  </main>
</Layout>
